# ─── Core ────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -base64 48
SESSION_SECRET=

# Optional: separate key for API-key field encryption at rest.
# Falls back to SESSION_SECRET if unset. At least 32 characters.
API_KEY_ENCRYPTION_SECRET=

# Public base URL of this app. Required so ElevenLabs can reach agent tool webhooks
# (Cal.com booking, rescheduling, etc.). In localhost dev, use ngrok or Cloudflare tunnel.
APP_URL=http://localhost:3000

# Shared secret attached to every tool webhook call. Tool routes reject calls whose
# X-NextNote-Secret header doesn't match. Generate with: openssl rand -hex 32
TOOLS_WEBHOOK_SECRET=

# ─── Supabase ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI Providers (platform-level keys — used as fallback when users
# haven't added their own key in Settings → AI API Keys) ──
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Email (Resend) ──────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Google OAuth (Calendar + Gmail) ─────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ─── Twilio (master reseller account) ─────────────────────
# Users don't bring their own Twilio creds — NextNote purchases numbers on this
# single master account and charges users via credits.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ─── Retell (AI voice) ───────────────────────────────────
# Users supply their own Retell key in Settings.

# ─── Outscraper (Google Maps prospect sourcing) ──────────
# Used by /dashboard/sources to import prospects by niche + location.
# Sign up at https://outscraper.com — pay-as-you-go ~$0.001-0.003 per place.
OUTSCRAPER_API_KEY=

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
